# OpenStore.ai — Environment Variables

# === REQUIRED ===

# Supabase (free tier at supabase.com)
# Get these from: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Moonshot AI (for brand analysis & product sourcing)
KIMI_API_KEY=sk-your-kimi-key
KIMI_MODEL=moonshot-v1-8k
KIMI_BASE_URL=https://api.moonshot.ai/v1

# Firecrawl (for real supplier listing search)
FIRECRAWL_API_KEY=fc-your-firecrawl-key

# === OPTIONAL (needed for billing) ===

# Stripe (register at stripe.com)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable

# === APP CONFIG ===

PORT=5000
NODE_ENV=development
BASE_URL=http://localhost:5000
JWT_SECRET=your-random-jwt-secret-at-least-32-chars
